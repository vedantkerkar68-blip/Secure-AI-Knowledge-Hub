# Google Gemini API key for LLM chat, streaming, embedding, and AI operations.
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# JWT signing secret for access and refresh tokens.
# Generate with: openssl rand -base64 64
# Minimum 256-bit (32 bytes) Base64-encoded secret.
# REQUIRED in production - application will fail to start if unset.
JWT_SECRET=

# PostgreSQL host address.
# Use "localhost" for local development or a container/service name in Docker.
DB_HOST=localhost

# PostgreSQL port (default: 5432).
DB_PORT=5432

# PostgreSQL database name.
# Must match the database created manually or by Docker Compose.
DB_NAME=sakh_db

# PostgreSQL database user.
# Must have read/write permissions on the specified database.
DB_USERNAME=postgres

# PostgreSQL database user password.
DB_PASSWORD=postgres

# Comma-separated list of allowed CORS origins for production.
# Example: https://my-frontend.vercel.app,https://admin.my-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
